//@version=6
indicator(title="BTCUSD MTF EMA Trend", shorttitle="MTF EMA", overlay=true)

// ── USER INPUTS ──────────────────────────────────────────────────────────────
fast_len    = input.int(21,    "Fast EMA",        minval=1, group="EMA Settings")
mid_len     = input.int(50,    "Mid EMA",         minval=1, group="EMA Settings")
slow_len    = input.int(200,   "Slow EMA",        minval=1, group="EMA Settings")
htf         = input.timeframe("240", "HTF Timeframe",       group="EMA Settings")
show_bg     = input.bool(true, "Show Background",            group="Display")
show_arrows = input.bool(true, "Show Arrows",                group="Display")
show_table  = input.bool(true, "Show Table",                 group="Display")

// ── MTF EMA ENGINE ───────────────────────────────────────────────────────────
ema_fast_15 = ta.ema(close, fast_len)
ema_mid_15  = ta.ema(close, mid_len)
ema_slow_15 = ta.ema(close, slow_len)

[ema_fast_4h, ema_mid_4h, ema_slow_4h, close_4h] = request.security(
    syminfo.tickerid, htf,
    [ta.ema(close, fast_len), ta.ema(close, mid_len), ta.ema(close, slow_len), close],
    lookahead=barmerge.lookahead_off)

// ── BIAS LOGIC ───────────────────────────────────────────────────────────────
f_bias(price, f, m, s) =>
    if price > f and f > m and m > s
        1
    else if price < f and f < m and m < s
        -1
    else
        0

bias_15 = f_bias(close,    ema_fast_15, ema_mid_15, ema_slow_15)
bias_4h = f_bias(close_4h, ema_fast_4h, ema_mid_4h, ema_slow_4h)

// Alignment score 0-3: count of correctly stacked relationships (15m and 4H)
score_15 = (close      > ema_fast_15  ? 1 : 0) +
           (ema_fast_15 > ema_mid_15   ? 1 : 0) +
           (ema_mid_15  > ema_slow_15  ? 1 : 0)

score_4h = (close_4h   > ema_fast_4h  ? 1 : 0) +
           (ema_fast_4h > ema_mid_4h   ? 1 : 0) +
           (ema_mid_4h  > ema_slow_4h  ? 1 : 0)

// ── SIGNAL GENERATOR ─────────────────────────────────────────────────────────
cross_up   = ta.crossover(ema_fast_15,  ema_mid_15)
cross_down = ta.crossunder(ema_fast_15, ema_mid_15)

// barstate.isconfirmed gates signals to bar close only — prevents repainting
long_signal  = barstate.isconfirmed and cross_up   and bias_4h == 1  and close > ema_slow_15
short_signal = barstate.isconfirmed and cross_down and bias_4h == -1 and close < ema_slow_15

// Persist last signal direction for the dashboard table (survives across bars)
var int last_direction = 0
if long_signal
    last_direction := 1
else if short_signal
    last_direction := -1

// ── EMA LINE PLOTS ───────────────────────────────────────────────────────────
plot(ema_fast_15, "EMA 21",  color=color.new(color.blue,   0), linewidth=1)
plot(ema_mid_15,  "EMA 50",  color=color.new(color.orange, 0), linewidth=1)
plot(ema_slow_15, "EMA 200", color=color.new(color.white,  0), linewidth=2)

// ── BACKGROUND RENDERER ──────────────────────────────────────────────────────
bg_col = not show_bg ? na : bias_4h == 1 ? color.new(color.green, 90) : bias_4h == -1 ? color.new(color.red, 90) : na
bgcolor(bg_col, title="Trend Background")

// ── ARROW RENDERER ───────────────────────────────────────────────────────────
plotshape(show_arrows and long_signal,
    title     = "Long Signal",
    style     = shape.labelup,
    location  = location.belowbar,
    color     = color.lime,
    textcolor = color.black,
    text      = "L",
    size      = size.small)

plotshape(show_arrows and short_signal,
    title     = "Short Signal",
    style     = shape.labeldown,
    location  = location.abovebar,
    color     = color.red,
    textcolor = color.white,
    text      = "S",
    size      = size.small)

// ── DASHBOARD TABLE ──────────────────────────────────────────────────────────
if show_table and barstate.islast
    var tbl = table.new(position.top_right, 3, 4,
        border_width = 1,
        border_color = color.gray,
        bgcolor      = color.new(color.black, 80))

    table.cell(tbl, 0, 0, "",    text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(tbl, 1, 0, "4H",  text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(tbl, 2, 0, "15m", text_color=color.white, bgcolor=color.new(color.gray, 50))

    bias_4h_str = bias_4h == 1 ? "Bullish" : bias_4h == -1 ? "Bearish" : "Neutral"
    bias_15_str = bias_15 == 1 ? "Bullish" : bias_15 == -1 ? "Bearish" : "Neutral"
    bias_4h_col = bias_4h == 1 ? color.green : bias_4h == -1 ? color.red : color.gray
    bias_15_col = bias_15 == 1 ? color.green : bias_15 == -1 ? color.red : color.gray
    table.cell(tbl, 0, 1, "Bias",      text_color=color.white)
    table.cell(tbl, 1, 1, bias_4h_str, text_color=bias_4h_col)
    table.cell(tbl, 2, 1, bias_15_str, text_color=bias_15_col)

    score_4h_col = score_4h >= 3 ? bias_4h_col : score_4h >= 2 ? color.orange : color.gray
    score_15_col = score_15 >= 3 ? bias_15_col : score_15 >= 2 ? color.orange : color.gray
    table.cell(tbl, 0, 2, "Score",                          text_color=color.white)
    table.cell(tbl, 1, 2, str.tostring(score_4h) + " / 3", text_color=score_4h_col)
    table.cell(tbl, 2, 2, str.tostring(score_15) + " / 3", text_color=score_15_col)

    last_sig_str = last_direction == 1 ? "▲ LONG" : last_direction == -1 ? "▼ SHORT" : "—"
    last_sig_col = last_direction == 1 ? color.lime : last_direction == -1 ? color.red : color.gray
    table.cell(tbl, 0, 3, "Signal",     text_color=color.white)
    table.cell(tbl, 1, 3, "—",          text_color=color.gray)
    table.cell(tbl, 2, 3, last_sig_str, text_color=last_sig_col)

// ── ALERT CONDITIONS ─────────────────────────────────────────────────────────
alertcondition(long_signal,
    title   = "BTCUSD Long Signal — MTF EMA Stack",
    message = "BTCUSD LONG ▲  |  MTF EMA Stack aligned bullish  |  Price: {{close}}  |  Time: {{time}}")

alertcondition(short_signal,
    title   = "BTCUSD Short Signal — MTF EMA Stack",
    message = "BTCUSD SHORT ▼  |  MTF EMA Stack aligned bearish  |  Price: {{close}}  |  Time: {{time}}")
